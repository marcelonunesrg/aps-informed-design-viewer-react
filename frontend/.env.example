# Frontend dev server port
VITE_DEV_SERVER_PORT="8080"

# Required for SPA PKCE OAuth flow
VITE_APS_CLIENT_ID="<your-aps-client-id>"

# Optional: defaults to current origin + pathname
# VITE_APS_REDIRECT_URI="http://localhost:8080/"

# Optional: defaults to the scopes below
# VITE_APS_SCOPES="data:read data:write data:create viewables:read account:read user-profile:read offline_access"
